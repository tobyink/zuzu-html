=encoding utf8

=head1 NAME

html/tags - shortcut functions for HTML generation.

=head1 SYNOPSIS

  from html/tags import *;
  from std/colour import parse_colour;
  
  let classes := [ "big", "bold" ];
  
  let doc := HTML(
    lang: "en",
    HEAD(
      META( charset: "utf8" ),
      TITLE( "Hello World" ),
      STYLE( ```
        .big   { font-size: 1.5rem; }
        .small { font-size: 0.75rem; }
        .bold  { font-weight: bold; }
        #intro { color: ${ parse_colour("blue") }; }
      ``` ),
    ),
    BODY(
      H1( "Hello World" ),
      P( class: classes, id: "intro", "This is an example." ),
      P( class: "small bold", "And now we're done." ),
    ),
  );
  
  say doc;

=head1 DESCRIPTION

This module provides shortcut functions for quickly constructing a DOM
in ZuzuScript.

=head1 EXPORTS

=head2 Functions

=head3 General Functions

=over

=item C<< html_tag( String tagname, ... PairList attrs, Array children ) → HTMLElement >>

Generic HTML tag; can be used to insert any element which this module
otherwise doesn't provide.

  let annoyance := html_tag( "blink", "This text flashes." );

Attributes are passed as named parameters:

  let link := html_tag( "a", href: "https://example.net/", "Link text" );

All other parameters (including plain strings) are treated as child nodes.

=cut

from html/dom import HTMLElement, HTMLText, HTMLNode, HTMLComment;

function html_tag ( String tagname, ... PairList attrs, Array children ) → HTMLElement {
	from std/internals import to_String;

	/*
	from std/dump import Dumper;
	warn Dumper.dump( [ tagname, attrs, children ] );
	*/

	// Create element
	let tag := new HTMLElement( _tag_name: lc tagname );

	// Add attributes
	function attr_to_str ( name, val ) {
		if ( name eq "class" and val instanceof Array ) {
			from std/string import join;
			return join(" ", val);
		}
		return to_String(val);
	}
	tag.setAttribute( ^^.key, ( ^^.value instanceof String ) ? ^^.value : attr_to_str( ^^.key, ^^.value ) ) for attrs.enumerate;

	// Add child nodes
	for ( const child in children ) {
		if ( child instanceof HTMLNode ) {
			tag.appendChild( child );
			next;
		}
		else {
			let childnode := new HTMLText( _node_value: to_String(child) );
			tag.appendChild( childnode );
		}
	}

	return tag;
}

=item C<< html_comment( String comment ) → HTMLComment >>

Used to insert an HTML comment.

=cut

function html_comment ( String comment ) → HTMLComment {
	return new HTMLComment( _node_value: comment );
}

=item C<< html_literal( String literal_html ) → HTMLNode >>

Used to insert literal HTML which will not be escaped during output.
Internally this is represented as a special HTMLComment node.

  let div := DIV(
    id: "example",
    P("This div contains two paragraphs, but one is commented out."),
    html_literal("<!-- "),
    P("This one should be commented out."),
    html_literal(" -->"),
  );

=cut

class _HTMLLiteral extends HTMLComment {

	method __build__ () {
		self._use_data_alias( self{_data} );
		self._configure_node( "comment", "#comment" );
		self._init_node;
	}

	method toHTML ( pretty := false ) {
		return self.data;
	}

	method cloneNode ( deep := false ) {
		return new _HTMLLiteral(
			_node_value:     self.data,
			_owner_document: self.ownerDocument,
		);
	}
}

function html_literal( String literal_html ) → HTMLNode {
	return new _HTMLLiteral( _node_value: literal_html );
}

=back

=head3 Main root

=over

=item C<< HTML(... PairList attrs, Array children ) → HTMLElement >>

Represents the top-level root element of an HTML document; every other element in the document is a descendant of it.

=cut

function HTML(... PairList attrs, Array children ) → HTMLElement {
	return html_tag( "html", ...attrs, ...children );
}

=back

=head3 Document metadata

=over

=item C<< BASE(... PairList attrs, Array children ) → HTMLElement >>

Sets the base URL used to resolve relative URLs in the document; only one base element is allowed.

=cut

function BASE(... PairList attrs, Array children ) → HTMLElement {
	return html_tag( "base", ...attrs, ...children );
}

=item C<< HEAD(... PairList attrs, Array children ) → HTMLElement >>

Contains document metadata such as the title, scripts, style sheets, links, and other machine-readable information.

=cut

function HEAD(... PairList attrs, Array children ) → HTMLElement {
	return html_tag( "head", ...attrs, ...children );
}

=item C<< LINK(... PairList attrs, Array children ) → HTMLElement >>

Declares a relationship between the current document and an external resource, commonly a style sheet or site icon.

=cut

function LINK(... PairList attrs, Array children ) → HTMLElement {
	return html_tag( "link", ...attrs, ...children );
}

=item C<< META(... PairList attrs, Array children ) → HTMLElement >>

Provides metadata that cannot be expressed by other metadata elements such as base, link, script, style, or title.

=cut

function META(... PairList attrs, Array children ) → HTMLElement {
	return html_tag( "meta", ...attrs, ...children );
}

=item C<< STYLE(... PairList attrs, Array children ) → HTMLElement >>

Contains CSS rules for the document or for a part of the document.

=cut

function STYLE(... PairList attrs, Array children ) → HTMLElement {
	return html_tag( "style", ...attrs, ...children );
}

=item C<< TITLE(... PairList attrs, Array children ) → HTMLElement >>

Defines the document title shown by browsers in the window title or tab label; markup inside it is treated as text.

=cut

function TITLE(... PairList attrs, Array children ) → HTMLElement {
	return html_tag( "title", ...attrs, ...children );
}

=back

=head3 Sectioning root

=over

=item C<< BODY(... PairList attrs, Array children ) → HTMLElement >>

Contains the visible and interactive content of an HTML document; a document has at most one body element.

=cut

function BODY(... PairList attrs, Array children ) → HTMLElement {
	return html_tag( "body", ...attrs, ...children );
}

=back

